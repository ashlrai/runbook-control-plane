{
  "name": "@runbook/session",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./charter-binding": {
      "types": "./src/charter-binding.ts",
      "default": "./dist/charter-binding.js"
    },
    "./pack-import": {
      "types": "./src/pack-import.ts",
      "default": "./dist/pack-import.js"
    },
    "./process-tick": {
      "types": "./src/process-tick.ts",
      "default": "./dist/process-tick.js"
    },
    "./process-capsule": {
      "types": "./src/process-capsule.ts",
      "default": "./dist/process-capsule.js"
    },
    "./clone-challenge": {
      "types": "./src/clone-challenge.ts",
      "default": "./dist/clone-challenge.js"
    },
    "./check-diff": {
      "types": "./src/check-diff.ts",
      "default": "./dist/check-diff.js"
    },
    "./process-health": {
      "types": "./src/process-health.ts",
      "default": "./dist/process-health.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "pretest": "pnpm --filter @runbook/engine build && pnpm build",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@runbook/engine": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
