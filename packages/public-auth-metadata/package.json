{
  "name": "@runbook/public-auth-metadata",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:fixtures": "node scripts/build-robinhood-fixtures.mjs",
    "capture:robinhood:candidate": "pnpm build && node scripts/capture-robinhood-candidate.mjs",
    "test": "pnpm --filter @runbook/financial-bench build && pnpm build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@runbook/financial-bench": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "license": "Apache-2.0"
}
