{
  "name": "@runbook/financial-capability-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "runbook-capabilities": "./dist/runbook-capabilities.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm build:cli",
    "build:cli": "node scripts/build-cli.mjs",
    "build:conformance": "node scripts/build-conformance-fixtures.mjs",
    "test": "pnpm --filter @runbook/financial-bench build && vitest run",
    "test:conformance": "pnpm --filter @runbook/financial-bench build && vitest run src/conformance.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@runbook/financial-bench": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "esbuild": "0.28.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "license": "Apache-2.0"
}
